# NotifyFlow - Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_URL=jdbc:postgresql://localhost:5432/notifyflow
DB_USERNAME=postgres
DB_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# SendGrid (Sprint 4)
# SENDGRID_API_KEY=

# Twilio (Sprint 4)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Firebase (Sprint 4)
# FCM_PROJECT_ID=
# FCM_CREDENTIALS_PATH=
